function getAngleDiff(a, b)
    local diff = a - b

    while diff > 180 do
        diff = diff - 360
    end

    while diff < -180 do
        diff = diff + 360
    end

    return diff
end

function startTurn(prev, current, next)

    local dir1 = getHeadingFromVector2d(
        current[1] - prev[1],
        current[2] - prev[2]
    )

    local dir2 = getHeadingFromVector2d(
        next[1] - current[1],
        next[2] - current[2]
    )

    local diff = getAngleDiff(dir2, dir1)

    if math.abs(diff) > TURN_ANGLE then

        turning = true
        turnTimer = os.clock() * 1000 + TURN_TIME

        if diff > 0 then
            turnDir = -255
        else
            turnDir = 255
        end
    end
end

function updateWalk()

    if not targetWood then
        scanActive = true
        walkActive = false
        chopActive = false
        return
    end

    local px, py, pz = getCharCoordinates(PLAYER_PED)

    local dist = getDistanceBetweenCoords3d(
        px, py, pz,
        targetWood.x,
        targetWood.y,
        pz
    )

    if turning then

        setGameKeyState(1, -128)
        setGameKeyState(16, 255)
        setGameKeyState(0, turnDir)

        if os.clock() * 1000 >= turnTimer then
            turning = false
            turnDir = 0
            setGameKeyState(0,0)
        end

        return
    end

    local heading = getHeadingFromVector2d(
        targetWood.x - px,
        targetWood.y - py
    )

    setCharHeading(PLAYER_PED, heading)

    setGameKeyState(1, -128)

    if dist <= 0.9 then

        setGameKeyState(1,0)
        setGameKeyState(16,0)
        setGameKeyState(0,0)

        walkActive = false
        chopActive = true
    end
end

